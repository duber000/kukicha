import "stdlib/slice"

func main()
    # Test 1: Basic filter with arrow lambda
    numbers := list of int{1, 2, 3, 4, 5}
    evens := numbers |> slice.Filter(n => n % 2 equals 0)
    print(evens)

    # Test 2: Map with arrow lambda
    doubled := numbers |> slice.Map(n => n * 2)
    print(doubled)

    # Test 3: Multiple statements in block lambda
    processed := numbers |> slice.Map((n int) =>
        squared := n * n
        adjusted := squared + 1
        return adjusted
    )
    print(processed)
